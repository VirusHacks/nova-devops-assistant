# InfraGuard — Environment Variables

# ── GitHub App ─────────────────────────────────────────────────────────────
# Your GitHub App ID (found at https://github.com/settings/apps/<your-app>)
GITHUB_APP_ID=your_app_id_here

# Private key: either paste the PEM content directly (with escaped newlines)
# OR set the path to the downloaded .pem file
GITHUB_PRIVATE_KEY_PATH=./private-key.pem
# GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Webhook secret you set when creating the GitHub App (random string)
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# ── Amazon Bedrock (Nova) ──────────────────────────────────────────────────
AWS_BEARER_TOKEN_BEDROCK=your_bedrock_api_key_here

# ── Server config ──────────────────────────────────────────────────────────
PORT=8000

# Base URL of the Next.js dashboard (used for "View report" links in PR comments)
# Example: https://your-app.vercel.app or http://localhost:3000
DASHBOARD_BASE_URL=http://localhost:3000
